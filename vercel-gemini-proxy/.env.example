# Gemini API key — never exposed to the mobile app or Cloud Functions, only
# lives here. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model id — check current available models for your API key/region and
# adjust; this is the only place the model name needs to change.
GEMINI_MODEL=gemini-2.5-flash

# Shared secret this proxy requires on every request (header: x-proxy-secret).
# Must match the same value set on the Cloud Functions side
# (GEMINI_PROXY_SHARED_SECRET, see functions/ and META_SETUP.md).
PROXY_SHARED_SECRET=

# Comma-separated list of caller identifiers allowed to bypass the per-minute
# rate limit cap (leave empty to apply the same limit to everyone).
RATE_LIMIT_PER_MINUTE=30
