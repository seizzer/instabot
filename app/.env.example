# Firebase web config (from Firebase Console > Project settings > General > Your apps)
# These are safe to expose to the client — they only identify the Firebase project,
# access is enforced by Firestore security rules and App Check, not by secrecy.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Meta App (from Meta Developer Dashboard) — used client-side to build the Instagram
# OAuth authorize URL. The app SECRET must never appear here; it lives only in
# Cloud Functions config. See META_SETUP.md.
EXPO_PUBLIC_META_APP_ID=
# Meta's Facebook Login dialog has required HTTPS redirect URIs since 2018 —
# a bare custom scheme (instabot://redirect) is rejected by the dashboard
# ("should represent a valid URL"). This must point at the static bounce page
# in /hosting (deployed via `firebase deploy --only hosting`), which
# redirects back into the app via instabot://redirect. Register the same
# exact URL in Meta App Dashboard > Facebook Login > Settings > Valid OAuth
# Redirect URIs.
EXPO_PUBLIC_META_OAUTH_REDIRECT_URI=https://instabot-app-tr.web.app/instagram-callback.html

# Meta App Client Token (Dashboard > Settings > Advanced > Security) — needed
# by react-native-fbsdk-next for native "Sign in with Facebook" (consumer
# auth, separate from the OAuth dialog above used for Instagram business
# account linking). Public/client-embeddable by Meta's own design.
EXPO_PUBLIC_META_CLIENT_TOKEN=

# WhatsApp Embedded Signup configuration id (Meta App Dashboard > Facebook
# Login for Business > Configurations) — powers ConnectWhatsAppScreen's
# WebView flow. See META_SETUP.md §10.7. Not required for the manual
# System-User-token connection path (dev/testing only).
EXPO_PUBLIC_META_WHATSAPP_CONFIG_ID=

# RevenueCat public SDK keys (per-platform, safe to expose)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Google Sign-In — the "Web client ID" (not the iOS/Android one) from the
# Firebase Console (Authentication > Sign-in method > Google) or Google Cloud
# Console credentials page. Required for Google login to work at all; without
# it the Google button simply doesn't render (see src/services/socialAuth.ts).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Apple Sign-In needs no client ID here — it's enabled via the "Sign in with
# Apple" capability in your Apple Developer account + the
# @react-native-google-signin/google-signin / expo-apple-authentication config
# already wired in app.config.ts. See META_SETUP.md.
